From e3a70f36196c4ae161d92d236932023a9fbf5238 Mon Sep 17 00:00:00 2001
From: Cursor Agent <agent@cursor.com>
Date: Wed, 8 Jul 2026 05:35:26 +0000
Subject: [PATCH] fix(hassfest): avoid angle-bracket channel placeholder in
 service descriptions

Hassfest rejects translation strings that look like HTML. Replace D<ch>
with D{channel} in strings.json, en/nl translations, and services.yaml.
---
 custom_components/ha_ipbuilding_gateway/services.yaml        | 4 ++--
 custom_components/ha_ipbuilding_gateway/strings.json         | 4 ++--
 custom_components/ha_ipbuilding_gateway/translations/en.json | 4 ++--
 custom_components/ha_ipbuilding_gateway/translations/nl.json | 4 ++--
 4 files changed, 8 insertions(+), 8 deletions(-)

diff --git a/custom_components/ha_ipbuilding_gateway/services.yaml b/custom_components/ha_ipbuilding_gateway/services.yaml
index 2a91c00..22b7c4b 100644
--- a/custom_components/ha_ipbuilding_gateway/services.yaml
+++ b/custom_components/ha_ipbuilding_gateway/services.yaml
@@ -2,7 +2,7 @@ dim_start:
   name: Start dim ramp
   description: >-
     Start a continuous hold-to-dim ramp on a dimmer channel. Sends
-    ``D<ch>001003`` to the IP0300PoE; the module ramps and auto-reverses
+    ``D{channel}001003`` to the IP0300PoE; the module ramps and auto-reverses
     direction on each successive hold. Pair with `dim_stop` to halt the ramp.
   target:
     entity:
@@ -12,7 +12,7 @@ dim_start:
 dim_stop:
   name: Stop dim ramp
   description: >-
-    Stop a dim ramp started by `dim_start`. Sends ``D<ch>001000``; the
+    Stop a dim ramp started by `dim_start`. Sends ``D{channel}001000``; the
     dimmer replies with the level reached when the stop landed.
   target:
     entity:
